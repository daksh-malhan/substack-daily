# Google Programmable Search Engine (image mode) — for supplemental "vibe" images.
# Optional: if unset, the app degrades to post-harvested images only.
# Get a key:   https://developers.google.com/custom-search/v1/overview
# Make a CSE:  https://programmablesearchengine.google.com/  (enable "Image search")
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# Optional overrides (defaults live in code):
# PORT=4321
